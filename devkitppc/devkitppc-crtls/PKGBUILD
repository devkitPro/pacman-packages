pkgname=('devkitppc-crtls')
pkgver=2.1.0
pkgrel=1
pkgdesc="devkitPPC crtls."
arch=('any')
license=('custom')
url="http://github.com/devkitpro/devkitppc-crtls"
source=(${pkgname}-${pkgver}.tar.gz::${url}/archive/refs/tags/v${pkgver}.tar.gz)

options=(!strip libtool staticlibs)

groups=('gamecube-dev' 'wii-dev')

package() {

  cd $srcdir/$pkgname-$pkgver
  make DESTDIR=$pkgdir install

}

sha256sums=('3b9cd2470130ced277fc759d6c1dbe255ea20f2311a4d83bba8bc185b5285533')
