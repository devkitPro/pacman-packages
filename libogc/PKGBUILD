# Maintainer: Dave Murphy <davem@devkitpro.org>

pkgname=('libogc')
pkgver=3.0.4
pkgrel=1
pkgdesc="Nintendo Gamecube & Wii library."
arch=('any')
license=('custom')
url="http://github.com/devkitpro/${pkgname}"
options=(!strip libtool staticlibs)
source=(${pkgname}-${pkgver}.tar.gz::${url}/archive/v${pkgver}.tar.gz)

makedepends=('devkitPPC')

groups=('wii-dev' 'gamecube-dev')

build() {
  cd ${srcdir}/libogc-${pkgver}
  LIBOGC_VER=v${pkgver} catnip
}

package() {
  cd ${srcdir}/libogc-${pkgver}
  LIBOGC_VER=v${pkgver} DESTDIR=$pkgdir catnip install
}

sha256sums=('dd0924ebc64e9d1811b54257e9b8ed3a966d35dc84b50003952988332665236e')
